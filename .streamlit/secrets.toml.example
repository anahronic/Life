# TEMPLATE: Copy this to .streamlit/secrets.toml (not committed to repo)
# On Streamlit Cloud, set these via Settings > Secrets

# TomTom API Key (from https://developer.tomtom.com/)
TOMTOM_API_KEY = "your-tomtom-api-key-here"

# Optional: Environment settings
ENVIRONMENT = "production"  # or "development"
CACHE_TTL_SECONDS = 300
RATE_LIMIT_SECONDS = 60
TOMTOM_QUOTA_PER_DAY = 2500  # TomTom free plan: 2500 calls/day

# Logging level
LOG_LEVEL = "INFO"  # DEBUG, INFO, WARNING, ERROR

# Optional: Allow sample mode for testing without API key
TT_ALLOW_SAMPLE = "0"  # Set to "1" to enable synthetic sample data

# Optional: Air quality point (Open‑Meteo fallback)
AQ_LAT = "32.078"
AQ_LON = "34.796"

# Optional: Override history DB location (default: ./data/monitor.sqlite3)
# HISTORY_DB_PATH = "/var/lib/ayalon/monitor.sqlite3"

# Optional: Force traffic mode (flow|sample). If unset: flow when key exists else sample.
# TRAFFIC_MODE = "flow"

# Optional: Official reference card (context-only)
# This is NOT a 1:1 benchmark against the live corridor vehicle-hours counters.
# If any required OFFICIAL_* value is missing, the UI will show "not configured".
#
# OFFICIAL_SOURCE_LABEL = "מבקר המדינה"  # or: "State Comptroller"
# OFFICIAL_REPORT_YEAR = "2023"
# OFFICIAL_REPORT_URL = "https://.../state-comptroller-report.pdf"
#
# OFFICIAL_METRIC_LABEL can be either:
#  - an i18n key defined in the app (recommended), or
#  - plain text (will display as-is)
# OFFICIAL_METRIC_LABEL = "official_metric_state_comptroller_congestion_cost"
#
# OFFICIAL_VALUE = "25000000000"
# OFFICIAL_UNIT = "ILS_per_year"  # currently supported: ILS_per_year
# OFFICIAL_VALUE_YEAR = "2021"     # optional, if value refers to a different year than the report
