# TEMPLATE: Copy this to .streamlit/secrets.toml (not committed to repo)
# On Streamlit Cloud, set these via Settings > Secrets
# NOTE: All values can also be set as plain env vars (preferred for VPS/systemd).

# TomTom API Key (from https://developer.tomtom.com/)
TOMTOM_API_KEY = "your-tomtom-api-key-here"

# Optional: Environment settings
ENVIRONMENT = "production"  # or "development"
CACHE_TTL_SECONDS = 300
RATE_LIMIT_SECONDS = 60
TOMTOM_QUOTA_PER_HOUR = 2500

# Logging level
LOG_LEVEL = "INFO"  # DEBUG, INFO, WARNING, ERROR

# Optional: Allow sample mode for testing without API key
TT_ALLOW_SAMPLE = "0"  # Set to "1" to enable synthetic sample data

# Optional: Air quality point (Open-Meteo fallback)
AQ_LAT = "32.078"
AQ_LON = "34.796"

# Optional: Override history DB location (default: ./data/monitor.sqlite3)
# HISTORY_DB_PATH = "/var/lib/ayalon/monitor.sqlite3"

# Optional: Force traffic mode (flow|sample). If unset: flow when key exists else sample.
# TRAFFIC_MODE = "flow"

# ─── Fuel price (3-adapter chain: CKAN → PDF → env) ─────────────────────
# Normally auto-fetched from data.gov.il. These overrides are optional.

# Emergency manual price override (skip CKAN + PDF entirely if set):
# FUEL_PRICE_ILS = "7.02"

# Formula tuning (defaults are derived from March 2026 data):
# FUEL_VAT_RATE = "0.18"
# FUEL_RETAIL_MARGIN_ILS = "0.66"

# CKAN resource IDs (pinned defaults rarely need changing):
# CKAN_FUEL_ORL_PRICES_RESOURCE = "aaa40832-ac82-4c86-bac6-0d05c83f576f"
# CKAN_FUEL_EXCISE_RESOURCE = "bdce45e7-9fe9-473e-bd51-cef1d787a951"
# CKAN_TIMEOUT_S = "20"

# ─── Official congestion benchmark ──────────────────────────────────────
# OFFICIAL_STATS_SOURCE_MODE = "auto"  # auto | url | static | disabled
# You can either point to a JSON URL:
# OFFICIAL_STATS_JSON_URL = "https://.../benchmark.json"
# Expected JSON key: hours_lost_per_person_per_year
# Or set a manual value:
# OFFICIAL_HOURS_LOST_PER_PERSON_PER_YEAR = "150"
# OFFICIAL_SOURCE_LABEL = "Gov.il (official estimate)"
